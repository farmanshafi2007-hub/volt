{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "roomCode": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat session between two or more users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantDetails": { "type": "object" },
        "lastMessage": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "senderId": { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["text", "image"] },
        "participants": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["senderId", "text", "timestamp", "type", "participants"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profile data."
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Metadata for a direct or group chat."
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Actual messages within a conversation."
    },
    "/conversations/{conversationId}/typing/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "isTyping": { "type": "boolean" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "participants": { "type": "array", "items": { "type": "string" } }
        }
      },
      "description": "Real-time typing status of a user in a conversation."
    }
  }
}
