rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastSeen']) && isValidUser(incoming())
      );

      function isValidUser(data) {
        return data.uid == request.auth.uid 
          && data.displayName is string && data.displayName.size() <= 100
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
          && (data.lastSeen == request.time || data.lastSeen is timestamp);
      }
    }

    // --- Conversations ---
    match /conversations/{conversationId} {
      function isGeneral() { return conversationId == 'general'; }
      
      // For the conversation document itself
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isGeneral() || resource.data.participants.hasAny([request.auth.uid]));
      
      allow create: if isSignedIn() && isValidConversation(incoming()) && incoming().participants.hasAny([request.auth.uid]);
      allow update: if isSignedIn() && (
        isGeneral() || existing().participants.hasAny([request.auth.uid])
      ) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['participants', 'lastMessage', 'updatedAt']) && isValidConversationUpdate(incoming()))
      );

      function isValidConversation(data) {
        return data.participants is list && data.participants.size() >= 1 && data.participants.size() <= 100
          && (data.createdAt == request.time || data.createdAt is timestamp);
      }

      function isValidConversationUpdate(data) {
        return (incoming().updatedAt == request.time || incoming().updatedAt is timestamp)
          && (!incoming().keys().hasAll(['participants']) || (incoming().participants is list && incoming().participants.size() <= 100));
      }

      // --- Messages Subcollection ---
      match /messages/{messageId} {
        function canAccessMessages() {
          return isGeneral() || (
            isSignedIn() && 
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid])
          );
        }

        allow read: if isSignedIn() && canAccessMessages();
        
        allow create: if isSignedIn() && canAccessMessages() 
          && incoming().userId == request.auth.uid
          && isValidMessage(incoming());
        
        allow delete: if isSignedIn() && existing().userId == request.auth.uid;
        allow update: if false;

        function isValidMessage(data) {
          return data.userId == request.auth.uid
            && data.text is string && data.text.size() <= 2000
            && (data.createdAt == request.time || data.createdAt is timestamp);
        }
      }
    }
  }
}
